{
  "manifest_version": 3,
  "name": "HappyLy",
  "version": "1.0",
  "description": "Listening between the lines — mental wellness companion",

  "permissions": [
    "tabs",       
    "storage",    
    "activeTab",  
    "scripting",  
    "alarms"      
  ],

  "host_permissions": [
    "<all_urls>"  
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_title": "HappyLy",
    "default_popup": "popup.html"
  },

  "icons": {}
}
